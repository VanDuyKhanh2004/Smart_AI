# Backend runtime env for docker-compose
NODE_ENV=production
PORT=5000
FRONTEND_URL=http://localhost:3000

# Database
MONGO_CONNECTION_STRING=mongodb://mongodb:27017/smart_ai

# AI
OPENAI_API_KEY=replace_with_your_openai_api_key
OPENAI_MODEL=gpt-4o

# JWT
JWT_SECRET=replace_with_a_strong_jwt_secret
JWT_EXPIRE=15m
JWT_REFRESH_SECRET=replace_with_a_strong_refresh_secret
JWT_REFRESH_EXPIRE=7d

# OAuth
GOOGLE_CLIENT_ID=

# Login security
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
LOGIN_IP_MAX_ATTEMPTS=20
LOGIN_IP_WINDOW_MINUTES=15
LOGIN_IP_BLOCK_MINUTES=15

# Email (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM=
